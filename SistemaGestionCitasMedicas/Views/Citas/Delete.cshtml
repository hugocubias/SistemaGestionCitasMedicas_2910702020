@model SistemaGestionCitasMedicas.Models.Cita

@{
    ViewData["Title"] = "Eliminar Cita";
}

<h1 class="mb-4">Eliminar Cita</h1>

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        Confirmar eliminación
    </div>
    <div class="card-body">
        <h5 class="mb-3">¿Estás seguro que deseas eliminar esta cita?</h5>
        <dl class="row">
            <dt class="col-sm-3">Fecha y Hora</dt>
            <dd class="col-sm-9">@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Paciente</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Paciente.Nombre)</dd>

            <dt class="col-sm-3">Médico</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Medico.Nombre)</dd>
        </dl>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="🗑️ Eliminar" class="btn btn-danger" />
        </form>
        <a asp-action="Index" class="btn btn-secondary">⬅️ Volver al listado</a>
    </div>
</div>
