@model IEnumerable<SistemaGestionCitasMedicas.Models.Cita>

@{
    ViewData["Title"] = "Citas";
}

<h1 class="mb-4">Listado de Citas</h1>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">➕ Crear Nueva Cita</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Fecha y Hora</th>
                    <th>Paciente</th>
                    <th>Médico</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.Paciente.Nombre</td>
                        <td>@item.Medico.Nombre</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">✏️ Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">🔍 Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑️ Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
