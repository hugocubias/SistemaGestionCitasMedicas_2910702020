@model SistemaGestionCitasMedicas.Models.Medico

@{
    ViewData["Title"] = "Eliminar Médico";
}

<h1 class="mb-4">Eliminar Médico</h1>

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        Confirmar eliminación
    </div>
    <div class="card-body">
        <h5 class="mb-3">¿Estás seguro que deseas eliminar este médico?</h5>
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Nombre)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Especialidad)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Especialidad)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Horario)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Horario)</dd>
        </dl>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="🗑️ Eliminar" class="btn btn-danger" />
        </form>
        <a asp-action="Index" class="btn btn-secondary">⬅️ Volver al listado</a>
    </div>
</div>
